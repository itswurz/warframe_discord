  "resources": {
    "Ferrite": {
      "description": "A dense, compressed iron-based ore found throughout Earth and Mercury. Ferrite is one of the most common crafting materials in the Origin System \u2014 the backbone of Grineer industrial manufacturing.",
      "source": "Earth, Mercury, Void, Neptune",
      "tb_use": "General crafting material. Accumulated from Grineer drop tables. Used in future Warframe and weapon blueprint crafting.",
      "emoji": "<:ferrite:1499750270199009320>",
      "thumbnail": "https://cdn.discordapp.com/attachments/1499564077075267617/1499883860090028173/Ferrite.png?ex=69f66b32&is=69f519b2&hm=2663c3a108ed65486c6062cbe61bc4dc7db88e6c2efa6b52f8ab7fb4e8bb569b&"
    },
    "Rubedo": {
      "description": "A blood-red crystalline mineral found on Phobos, Earth, Sedna, Europa, and the Void. Rubedo's unique electromagnetic properties make it invaluable in advanced component construction.",
      "source": "Phobos, Earth, Europa, Sedna, Void",
      "tb_use": "Uncommon crafting material. Required for intermediate and advanced weapon/Warframe blueprints. Rarer than Ferrite \u2014 stockpile carefully.",
      "emoji": "<:rubedo:1499750208022773931>",
      "thumbnail": "https://cdn.discordapp.com/attachments/1499564077075267617/1499883853089607760/Rubedo.png?ex=69f66b31&is=69f519b1&hm=1bb836c48b02107e962895af75e83528cec4dc22983e130a7640f9b904c2178b&"
    },
    "Neurodes": {
      "description": "Rare biological nodes recovered from Infested-contaminated organisms. Neurodes contain dense neural tissue that interfaces with Orokin-era technology \u2014 indispensable for high-tier crafting.",
      "source": "Earth, Eris, Lua, Deimos",
      "tb_use": "Rare crafting material. Essential for Warframe Neuroptics and high-level weapon components. Extremely valuable \u2014 do not sell.",
      "emoji": "<:neurodes:1499750148991881366>",
      "thumbnail": "https://cdn.discordapp.com/attachments/1499564077075267617/1499883845887987824/Neurodes.png?ex=69f66b2f&is=69f519af&hm=4be9e8ca9590ed5ca393170dc76081f31724fb2fcdf00025363cd1fa157b79be&"
    },
    "Detonite Ampule": {
      "description": "Pressurized containers of Grineer-manufactured explosive compound. Originally used in Grineer demolition charges and missile warheads, these ampules are repurposed by the Tenno for component synthesis.",
      "source": "Grineer enemies, Grineer Caches, Invasion rewards",
      "tb_use": "Uncommon crafting material. Used in Grineer-tier weapon blueprints and some Warframe components. Keep a reserve for future crafting.",
      "emoji": "<:d_ampule:1499750066913673256>",
      "thumbnail": "https://cdn.discordapp.com/attachments/1499564077075267617/1499883838413865181/DetoniteAmpule.png?ex=69f66b2d&is=69f519ad&hm=90011ed6a3df3939fe4130b31e515d71440457ba54e56e8b94a524aade905678&"
    },
    "Endo": {
      "description": "Concentrated Orokin bio-matter used exclusively to rank up Mods. Endo is extracted from enemy neural pathways and combat data crystals. There is no substitute for Endo in the Mod leveling process.",
      "source": "Universal drop \u2014 enemies, missions, Transmutation, Arbitrations",
      "tb_use": "Used to rank up Mods from 0 to their maximum rank. Higher mod ranks require exponentially more Endo. A mod at rank 10 costs 8,145 total Endo to fully upgrade.",
      "emoji": "<:endo:1499750353002954792>",
      "thumbnail": "https://cdn.discordapp.com/attachments/1499564077075267617/1499883867551568053/Endo.png?ex=69f66b34&is=69f519b4&hm=60c77a5b559a2d42e7262792688ac5dfe74109a442b767d41af25ed003ec9a88&"
    }
  },
  "cosmetics": {
    "Sand Yellow Pigment": {
      "description": "A fine ochre pigment extracted from Grineer desert-pattern camo compounds. Tenno colourists prize this hue for replicating the dusty tones of Phobos and Mars surface units.",
